# ==============================================================================
# NextOSINT Environment Configuration
# ==============================================================================
# This file serves as the single source of truth for all environment variables.
# Copy this file to `.env` in the respective directories or at the root.
# ==============================================================================

# ─── System & Network ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Security & Authentication ──────────────────────────────────────────────
# URL allowed to make requests to the API (CORS). Comma-separated.
ALLOWED_ORIGIN=http://localhost:3000
# JWT secret for signing authentication tokens. Use a strong, random 32+ char string in production.
JWT_SECRET=super-secret-development-key-that-must-be-changed
# JWT expiration time (e.g., "24h", "7d")
JWT_EXPIRES_IN=24h

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Connection string for Prisma + PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/nextosint?schema=public
# If using Docker, use: postgresql://postgres:password@postgres:5432/nextosint?schema=public

# ─── Caching & Rate Limiting (Redis) ────────────────────────────────────────
# Redis connection string
REDIS_URL=redis://localhost:6379
# If using Docker, use: redis://redis:6379
# Time-to-Live for cached OSINT responses (in seconds)
CACHE_TTL_SECONDS=900
# Maximum requests per IP within the time window
RATE_LIMIT_MAX=100
# Time window for rate limiting (in milliseconds)
RATE_LIMIT_WINDOW_MS=60000

# ─── AI Integration (Anthropic) ─────────────────────────────────────────────
# REQUIRED: Your Anthropic API key for generating AI synthesis reports
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx
# The model to use (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ==============================================================================
# ─── OSINT API Keys (Optional) ──────────────────────────────────────────────
# All OSINT sources gracefully degrade if left blank. The system will skip
# them and note their unavailability in the final generated AI report.
# ==============================================================================

# Have I Been Pwned API Key
HIBP_API_KEY=

# Shodan API Key
SHODAN_API_KEY=

# VirusTotal API Key
VIRUSTOTAL_API_KEY=

# IPInfo Token
IPINFO_TOKEN=

# AbuseIPDB API Key
ABUSEIPDB_API_KEY=

# Hunter.io API Key
HUNTER_API_KEY=
