# ==============================================================================
# NextOSINT — Environment Configuration Template
# ==============================================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit the real `.env` file to version control.
# ==============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Security & Auth ────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000
JWT_SECRET=your-random-64-char-secret-here
JWT_EXPIRES_IN=24h

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/nextosint?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=900
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── AI (Anthropic Claude) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── OSINT API Keys (all optional — graceful degradation) ───────────────────
HIBP_API_KEY=
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
IPINFO_TOKEN=
ABUSEIPDB_API_KEY=
HUNTER_API_KEY=
